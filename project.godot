; Engine Configuration File.
; Godot version: 4.4

[application]
config/name="Texas Hold'em Poker"
config/description="A dark blue themed Texas Hold'em Poker game"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "Mobile")
